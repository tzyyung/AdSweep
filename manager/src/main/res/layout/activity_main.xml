<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <!-- Title Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1976D2"
        android:padding="16dp"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="AdSweep Manager"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="v1.0"
            android:textColor="#B0BEC5"
            android:textSize="12sp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- Step 1: Select App -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FFFFFF"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:id="@+id/step1Status"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:text="1"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:background="#1976D2" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Select App"
                        android:textSize="15sp"
                        android:textColor="#333333"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvStep1Info"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tap to choose an app"
                        android:textSize="13sp"
                        android:textColor="#757575" />
                </LinearLayout>

                <Button
                    android:id="@+id/btnSelect"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="SELECT"
                    android:textSize="12sp"
                    android:backgroundTint="#1976D2"
                    android:textColor="#FFFFFF" />
            </LinearLayout>

            <!-- Step 2: Backup + Patch (auto) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FFFFFF"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:id="@+id/step2Status"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:text="2"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:background="#9E9E9E" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Backup + Patch"
                        android:textSize="15sp"
                        android:textColor="#333333"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvStep2Info"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Waiting..."
                        android:textSize="13sp"
                        android:textColor="#757575" />
                </LinearLayout>

                <Button
                    android:id="@+id/btnPatch"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="PATCH"
                    android:textSize="12sp"
                    android:backgroundTint="#4CAF50"
                    android:textColor="#FFFFFF"
                    android:enabled="false" />
            </LinearLayout>

            <!-- Step 3: Uninstall Original -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FFFFFF"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:id="@+id/step3Status"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:text="3"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:background="#9E9E9E" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Uninstall Original"
                        android:textSize="15sp"
                        android:textColor="#333333"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvStep3Info"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Waiting..."
                        android:textSize="13sp"
                        android:textColor="#757575" />
                </LinearLayout>

                <Button
                    android:id="@+id/btnUninstall"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="UNINSTALL"
                    android:textSize="12sp"
                    android:backgroundTint="#FF9800"
                    android:textColor="#FFFFFF"
                    android:enabled="false" />
            </LinearLayout>

            <!-- Step 4: Install Patched -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FFFFFF"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:id="@+id/step4Status"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:text="4"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:background="#9E9E9E" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Install Patched"
                        android:textSize="15sp"
                        android:textColor="#333333"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvStep4Info"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Waiting..."
                        android:textSize="13sp"
                        android:textColor="#757575" />
                </LinearLayout>

                <Button
                    android:id="@+id/btnInstall"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="INSTALL"
                    android:textSize="12sp"
                    android:backgroundTint="#1976D2"
                    android:textColor="#FFFFFF"
                    android:enabled="false" />
            </LinearLayout>

            <!-- Log -->
            <LinearLayout
                android:id="@+id/cardLog"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FFFFFF"
                android:orientation="vertical"
                android:padding="16dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Log"
                    android:textColor="#1976D2"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvLog"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="#757575"
                    android:textSize="11sp"
                    android:fontFamily="monospace" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
