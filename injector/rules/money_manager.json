{
  "version": 1,
  "rules": [
    {
      "id": "mm-signature-check",
      "className": "com.realbyte.money.ui.main.Main",
      "methodName": "C2",
      "action": "BLOCK_RETURN_FALSE",
      "enabled": true,
      "source": "MANUAL",
      "sdkName": "Signature Check",
      "notes": "Signature verification bypass \u2014 C2() returns true if signature mismatch",
      "description": "Bypass APK signature verification"
    },
    {
      "id": "mm-globals-premium",
      "className": "com.realbyte.money.config.Globals",
      "methodName": "k",
      "action": "BLOCK_RETURN_TRUE",
      "enabled": true,
      "source": "MANUAL",
      "sdkName": "Premium Check",
      "notes": "k() is isPremium check; return true so e()=!k()=false, skipping purchase flow",
      "description": "Spoof premium/paid status"
    },
    {
      "id": "mm-globals-check",
      "className": "com.realbyte.money.config.Globals",
      "methodName": "j",
      "action": "BLOCK_RETURN_FALSE",
      "enabled": true,
      "source": "MANUAL",
      "sdkName": "License Check",
      "notes": "Additional license/integrity check",
      "description": "Bypass license integrity check"
    },
    {
      "id": "mm-analytics-noop",
      "className": "com.realbyte.money.utils.log_analytics.RbAnalyticAgent",
      "methodName": "a",
      "action": "BLOCK_RETURN_VOID",
      "enabled": true,
      "source": "MANUAL",
      "sdkName": "Analytics",
      "notes": "Firebase Analytics tracking",
      "description": "Disable Firebase Analytics tracking"
    },
    {
      "id": "mm-device-id",
      "className": "com.realbyte.money.cloud.util.DeviceAdId",
      "methodName": "b",
      "action": "BLOCK_RETURN_EMPTY_STRING",
      "enabled": true,
      "source": "MANUAL",
      "sdkName": "Device ID",
      "notes": "Block device ad ID collection",
      "description": "Block advertising device ID collection"
    },
    {
      "id": "mm-remote-request",
      "className": "com.realbyte.money.utils.remote.RbRemoteRequest",
      "methodName": "i",
      "action": "BLOCK_RETURN_VOID",
      "enabled": true,
      "source": "MANUAL",
      "sdkName": "Remote Request",
      "notes": "Block remote API requests",
      "description": "Block remote telemetry requests"
    },
    {
      "id": "mm-gdpr-consent-check",
      "className": "com.realbyte.money.ad.gdpr.GDPRConsent",
      "methodName": "l",
      "action": "BLOCK_RETURN_TRUE",
      "enabled": true,
      "source": "MANUAL",
      "sdkName": "GDPR Consent",
      "notes": "l() checks if consent obtained; return true to skip consent dialog entirely",
      "description": "Skip GDPR consent dialog"
    },
    {
      "id": "mm-ump-load-consent",
      "className": "com.google.android.ump.UserMessagingPlatform",
      "methodName": "loadAndShowConsentFormIfRequired",
      "action": "BLOCK_RETURN_VOID",
      "enabled": true,
      "source": "MANUAL",
      "sdkName": "UMP Consent",
      "notes": "Block Google UMP consent form",
      "description": "Skip Google UMP consent form"
    },
    {
      "id": "mm-ump-load-form",
      "className": "com.google.android.ump.UserMessagingPlatform",
      "methodName": "loadConsentForm",
      "action": "BLOCK_RETURN_VOID",
      "enabled": true,
      "source": "MANUAL",
      "sdkName": "UMP Consent",
      "notes": "Block Google UMP consent form loading",
      "description": "Skip Google UMP consent form loading"
    }
  ]
}
