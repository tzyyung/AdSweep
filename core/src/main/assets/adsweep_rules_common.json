    {
      "id": "ump-load-show-consent",
      "className": "com.google.android.ump.UserMessagingPlatform",
      "methodName": "loadAndShowConsentFormIfRequired",
      "action": "BLOCK_RETURN_VOID",
      "enabled": true,
      "source": "BUILTIN",
      "sdkName": "Google UMP",
      "description": "Skip Google consent form (GDPR/UMP)"
    },
    {
      "id": "ump-load-consent-form",
      "className": "com.google.android.ump.UserMessagingPlatform",
      "methodName": "loadConsentForm",
      "action": "BLOCK_RETURN_VOID",
      "enabled": true,
      "source": "BUILTIN",
      "sdkName": "Google UMP",
      "description": "Skip Google consent form loading"
    },
    {
      "id": "network-okhttp-block",
      "className": "okhttp3.OkHttpClient",
      "methodName": "newCall",
      "condition": {
        "type": "URL_MATCHES",
        "argIndex": 1,
        "extract": "url"
      },
      "action": "BLOCK_RETURN_NULL",
      "enabled": true,
      "source": "BUILTIN",
      "sdkName": "Network (OkHttp)",
      "notes": "Block ad domain requests via OkHttp",
      "description": "Block ad domain requests via OkHttp"
    },
    {
      "id": "network-url-block",
      "className": "java.net.URL",
      "methodName": "openConnection",
      "condition": {
        "type": "URL_MATCHES",
        "argIndex": 0,
        "extract": "toString"
      },
      "action": "BLOCK_RETURN_NULL",
      "enabled": true,
      "source": "BUILTIN",
      "sdkName": "Network (HttpURLConnection)",
      "notes": "Block ad domain requests via HttpURLConnection",
      "description": "Block ad domain requests via HttpURLConnection"
    },
    {
      "id": "universal-signature-spoof",
      "className": "android.app.ApplicationPackageManager",
      "methodName": "getPackageInfo",
      "paramTypes": [
        "java.lang.String",
        "int"
      ],
      "action": "SPOOF_SIGNATURE",
      "enabled": true,
      "source": "BUILTIN",
      "sdkName": "Tamper Detection",
      "description": "Return original APK signature to bypass tamper detection"
    }
